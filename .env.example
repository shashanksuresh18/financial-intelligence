# Financial Intelligence — Environment Variables
# Copy to .env.local: cp .env.example .env.local

# Claude API (REQUIRED) — get from console.anthropic.com
ANTHROPIC_API_KEY=
# Exa Deep (REQUIRED for private-company analysis and Themes)
EXA_API_KEY=
# Nebius Token Factory (OPTIONAL for memo synthesis / RAG)
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_LLM_MODEL=
NEBIUS_EMBED_MODEL=
USE_NEBIUS_MEMO=false

# Finnhub (REQUIRED) — free at finnhub.io/register
FINNHUB_API_KEY=

# Financial Modeling Prep (OPTIONAL for P2 valuation depth) - paid at site.financialmodelingprep.com
FMP_API_KEY=

# Companies House UK (RECOMMENDED) — free at developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# GLEIF — no key needed
# SEC EDGAR — no key needed, just set user agent email below
SEC_EDGAR_USER_AGENT=yourname@email.com

# Database
DATABASE_URL=file:./prisma/dev.db
# Optional durable production storage
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
