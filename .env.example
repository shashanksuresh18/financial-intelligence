# Financial Intelligence — Environment Variables
# Copy to .env.local: cp .env.example .env.local

# Claude API (REQUIRED) — get from console.anthropic.com
ANTHROPIC_API_KEY=

# Finnhub (REQUIRED) — free at finnhub.io/register
FINNHUB_API_KEY=

# Companies House UK (RECOMMENDED) — free at developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# GLEIF — no key needed
# SEC EDGAR — no key needed, just set user agent email below
SEC_EDGAR_USER_AGENT=yourname@email.com

# Database
DATABASE_URL=file:./dev.db
